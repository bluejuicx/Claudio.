import discord
from discord import app_commands
from discord.ext import commands

class RepeatButton(discord.ui.View):
    def __init__(self):
        super().__init__(timeout=None)  # timeout=None = persiste
    
    @discord.ui.button(label="Repetir Mensaje", style=discord.ButtonStyle.primary, emoji="🔁")
    async def repeat_button(self, interaction: discord.Interaction, button: discord.ui.Button):
        # Aquí defines el mensaje que se repetirá
        mensaje_a_repetir = "¡Este es un mensaje repetido automáticamente! 🚀"
        
        try:
            await interaction.response.send_message(mensaje_a_repetir, ephemeral=False)
        except:
            # Si ya se respondió, usar followup
            await interaction.followup.send(mensaje_a_repetir)


class CustomMessageCog(commands.Cog):
    def __init__(self, bot: commands.Bot):
        self.bot = bot
    
    @app_commands.command(name="custommessage", description="Envía un mensaje con botón para repetir")
    @app_commands.describe(
        titulo="Título del embed (opcional)",
        contenido="El contenido del mensaje"
    )
    async def custommessage(
        self,
        interaction: discord.Interaction,
        contenido: str,
        titulo: str = None
    ):
        embed = discord.Embed(
            title=titulo or "Mensaje Personalizado",
            description=contenido,
            color=discord.Color.blue()
        )
        embed.set_footer(text=f"Enviado por {interaction.user}")
        
        view = RepeatButton()
        
        await interaction.response.send_message(embed=embed, view=view, ephemeral=False)


async def setup(bot: commands.Bot):
    await bot.add_cog(CustomMessageCog(bot))
